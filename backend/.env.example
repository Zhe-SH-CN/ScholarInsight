# ============================================================
# CompeteGraph Backend - 环境变量示例
# 复制为 .env 后填入真实值
# ============================================================

# --- LLM ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 备用模型（W2 之后启用）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 火山方舟 / Doubao（OpenAI 兼容协议）
# CG_LLM_PROVIDER=ark
# CG_LLM_MODEL=你的 Endpoint ID，例如 ep-xxxxxxxxxxxxxxxxxxxxx
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- 搜索 ---
SERPER_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
SEARCHAPI_API_KEY=
BING_SEARCH_API_KEY=
EXA_API_KEY=
SEARXNG_BASE_URL=
ZHIHU_API_KEY=               # 知乎搜索 API Key（用于中文用户声音搜索）
CG_SEARCH_PROVIDERS=tavily,exa,zhihu_inner,zhihu_global
CG_SEARCH_USE_ALL_PROVIDERS=true
CG_SEARCH_PROVIDER_TIMEOUT_SECONDS=12
CG_SEARCH_DEFAULT_RESULTS_PER_PROVIDER=5
CG_SEARCH_MAX_RESULTS_PER_PROVIDER=12
TAVILY_SEARCH_DEPTH=basic
SERPAPI_ENGINE=google
SEARCHAPI_ENGINE=google
BING_SEARCH_MARKET=en-US
EXA_SEARCH_TYPE=auto
SEARXNG_CATEGORIES=general
SEARXNG_LANGUAGE=all

# --- Agent 循环参数 ---
CG_MAX_SEARCH_ROUNDS=3       # Search Agent 内层 ReAct 最大轮次（每轮调用 LLM 推理下一步搜什么）
CG_MAX_RESEARCH_LOOPS=3      # Planning→Search→Evidence→Analysis 外层最大循环次数（Analysis 反馈缺口后重新规划）
CG_MIN_COVERAGE_TO_STOP=0.85 # 覆盖度达到此比例且无关键缺口时 Search Agent 才提前收敛

# --- 运行参数 ---
CG_DATA_DIR=../data          # 相对 backend/ 的路径
CG_MAX_PARALLEL_NODES=4      # 单 Run 最大并发节点数
CG_EVIDENCE_LLM_PARALLELISM=2 # Evidence 阶段 LLM 抽取并发数；Ark 等低 RPM endpoint 建议 1-2
CG_MAX_BUDGET_CNY=2.0        # 单 Run 默认预算上限（元）
CG_LLM_CACHE_TTL_DAYS=7      # LLM 响应缓存有效期
CG_LLM_TIMEOUT_SECONDS=90    # 单次 LLM 请求超时秒数
CG_LLM_MIN_INTERVAL_SECONDS=1.2 # 全局 LLM 请求最小间隔，避免 RPM 超限
CG_LLM_MAX_RETRIES=3         # 429/临时失败时最大重试次数
CG_LLM_RATE_LIMIT_COOLDOWN_SECONDS=12 # 429 后冷却秒数，会随重试次数递增

# --- HTTP ---
CG_HTTP_TIMEOUT_SECONDS=30
CG_HTTP_PROXY=               # 海外站点访问代理，留空则直连
CG_USER_AGENT=CompeteGraphBot/0.1 (+https://example.com)

# --- 日志 ---
CG_LOG_LEVEL=INFO            # DEBUG / INFO / WARNING / ERROR
CG_LOG_JSON=false            # true 时打 JSON 日志（生产）

# --- CORS（开发用）---
CG_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
