# ============================================================
# ScholarInsight Backend - environment example
# Copy to backend/.env and fill real credentials.
# ============================================================

# --- LLM: main analysis ---
CG_LLM_PROVIDER=mimo
CG_LLM_MODEL=mimo-v2.5-pro
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# --- LLM: optional red-team reviewer ---
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-pro-agent

# --- Alternative OpenAI-compatible providers ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- Local paper library ---
SCHOLAR_PAPER_INDEX_PATH=/home/zsz/Mimo/ScholarInsight/backend/data/paper_index.json
SCHOLAR_LOCAL_PAPERS_DIR=/home/zsz/papers

# --- Optional external search fallback ---
SERPER_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
SEARCHAPI_API_KEY=
BING_SEARCH_API_KEY=
EXA_API_KEY=
SEARXNG_BASE_URL=
ZHIHU_API_KEY=
CG_SEARCH_PROVIDERS=tavily,exa,zhihu_inner,zhihu_global
CG_SEARCH_USE_ALL_PROVIDERS=false
CG_SEARCH_PROVIDER_TIMEOUT_SECONDS=12
CG_SEARCH_DEFAULT_RESULTS_PER_PROVIDER=5
CG_SEARCH_MAX_RESULTS_PER_PROVIDER=12
TAVILY_SEARCH_DEPTH=basic
SERPAPI_ENGINE=google
SEARCHAPI_ENGINE=google
BING_SEARCH_MARKET=en-US
EXA_SEARCH_TYPE=auto
SEARXNG_CATEGORIES=general
SEARXNG_LANGUAGE=all

# --- Agent loops ---
CG_MAX_SEARCH_ROUNDS=3
CG_MAX_RESEARCH_LOOPS=5
CG_MIN_COVERAGE_TO_STOP=0.85

# --- Runtime ---
CG_DATA_DIR=../data
CG_MAX_PARALLEL_NODES=4
CG_EVIDENCE_LLM_PARALLELISM=2
CG_MAX_BUDGET_CNY=2.0
CG_LLM_CACHE_TTL_DAYS=7
CG_LLM_TIMEOUT_SECONDS=300
CG_LLM_MIN_INTERVAL_SECONDS=1.2
CG_LLM_MAX_RETRIES=3
CG_LLM_RATE_LIMIT_COOLDOWN_SECONDS=12

# --- HTTP ---
CG_HTTP_TIMEOUT_SECONDS=30
CG_HTTP_PROXY=
CG_USER_AGENT=ScholarInsightBot/0.1 (+https://example.com)

# --- Logging ---
CG_LOG_LEVEL=INFO
CG_LOG_JSON=false

# --- CORS ---
CG_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Auth ---
CG_AUTH_USERNAME=your-demo-user
CG_AUTH_PASSWORD=change-me
CG_AUTH_SECRET=replace-with-a-long-random-secret
